<Window
    x:Class="CodexConfigSwitcher.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Codex Config Switcher for Windows">
    <Grid
        x:Name="RootLayout"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Margin="24,24,24,0"
            Padding="20"
            Background="{StaticResource BrandSandBrush}"
            BorderBrush="{StaticResource BrandMintStrongBrush}"
            BorderThickness="1"
            CornerRadius="20">
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.3*" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock
                        Text="Windows 工作台"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource BrandSlateBrush}" />
                    <TextBlock
                        Text="{Binding LiveSummaryLine}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Text="{Binding PathsSummaryLine}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock
                        Text="目标应用"
                        FontWeight="SemiBold" />
                    <TextBlock Text="{Binding TargetSummaryLine}" TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Text="{Binding CliBridgeLine}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock
                        Text="最近状态"
                        FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LastAppliedLine}" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="刷新" Click="RefreshButton_Click" />
                        <Button Content="重启目标应用" Click="RestartTargetButton_Click" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid
            Grid.Row="1"
            Margin="24"
            ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            Text="预设库"
                            FontSize="22"
                            FontWeight="SemiBold" />
                        <TextBlock
                            Text="{Binding PresetCountLine}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <ListView
                        Grid.Row="1"
                        ItemsSource="{Binding Presets}"
                        SelectedItem="{Binding SelectedPreset, Mode=TwoWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="4,6" Spacing="4">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SummaryLine}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding BaseUrl}" FontSize="12" TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="20">
                    <Border
                        Padding="18"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="20">
                        <StackPanel Spacing="12">
                            <TextBlock
                                Text="当前选中预设"
                                FontSize="22"
                                FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedPresetNameLine}" FontSize="18" FontWeight="SemiBold" />
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding SelectedPresetModelLine}" />
                                    <TextBlock Text="{Binding SelectedPresetReviewModelLine}" />
                                    <TextBlock Text="{Binding SelectedPresetAuthLine}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8">
                                    <TextBlock Text="{Binding SelectedPresetProviderLine}" />
                                    <TextBlock Text="{Binding SelectedPresetBaseUrlLine}" TextWrapping="WrapWholeWords" />
                                    <TextBlock Text="{Binding SelectedPresetEnvironmentLine}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Content="应用预设" Click="ApplyButton_Click" />
                                <Button Content="应用并重启" Click="ApplyAndRestartButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="18"
                        Background="{StaticResource BrandMintBrush}"
                        BorderBrush="{StaticResource BrandMintStrongBrush}"
                        BorderThickness="1"
                        CornerRadius="20">
                        <StackPanel Spacing="12">
                            <TextBlock
                                Text="目标应用控制"
                                FontSize="22"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource BrandSlateBrush}" />
                            <TextBlock Text="{Binding TargetSummaryLine}" />
                            <TextBox
                                Header="目标应用路径"
                                Text="{Binding TargetPathDraft, Mode=TwoWay}" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Content="保存路径" Click="SaveTargetPathButton_Click" />
                                <Button Content="恢复默认目标" Click="ResetTargetPathButton_Click" />
                                <Button Content="重启目标应用" Click="RestartTargetButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border
            Grid.Row="2"
            Margin="24,0,24,24"
            Padding="16"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="16">
            <StackPanel Spacing="6">
                <ProgressRing IsActive="{Binding IsBusy}" Width="20" Height="20" />
                <TextBlock
                    Text="{Binding StatusMessage}"
                    Foreground="{StaticResource BrandMintStrongBrush}"
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    Text="{Binding ErrorMessage}"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
